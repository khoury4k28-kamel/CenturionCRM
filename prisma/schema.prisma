// Centurion CRM database schema.
// See /Users/kam/.claude/plans/we-re-going-to-make-merry-parnas.md for design notes.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ────────────────────────────────────────────────────────────
//  Users
// ────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  role          String    @default("MEMBER") // OWNER | MEMBER
  emailVerified DateTime?
  image         String?
  createdDeals  Deal[]    @relation("DealCreator")
  tasks         Task[]
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// NextAuth tables (Prisma adapter)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ────────────────────────────────────────────────────────────
//  Deals  (the central object)
// ────────────────────────────────────────────────────────────

model Deal {
  id               String         @id @default(cuid())
  stage            String         @default("NEW_LEAD") // see DealStage union in lib/types.ts
  property         Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId       String         @unique
  seller           Contact?       @relation("DealSeller", fields: [sellerId], references: [id])
  sellerId         String?
  realtor          Contact?       @relation("DealRealtor", fields: [realtorId], references: [id])
  realtorId        String?
  askingPrice      Decimal?
  ourOffer         Decimal?
  agreedPrice      Decimal? // PURCHASE PRICE in the spread view
  listPrice        Decimal? // MLS resale price
  acceptanceDate   DateTime? // date seller signed agreement
  expirationDate   DateTime? // date agreement expires
  termOfAgreement  String? // free-form, e.g. "60 DAYS", "90 DAYS - OPTION"
  amountOwed       Decimal? // null/0 renders as "-0-"
  weOwn            Boolean        @default(false) // when true, OWED renders "WE OWN"
  flaggedForReview Boolean        @default(false) // yellow row in the spread view
  agreementType    String? // PURCHASE | OPTION
  source           String? // "Fast Track for Elite", etc.
  notes            String?
  tasks            Task[]
  documents        Document[]
  emails           EmailMessage[]
  createdBy        User           @relation("DealCreator", fields: [createdById], references: [id])
  createdById      String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([stage])
  @@index([updatedAt])
}

// SQLite doesn't support enums; we keep them as strings + a TS union in lib/types.ts.
// DealStage      = NEW_LEAD | RESEARCHING | CONTACTED | NEGOTIATING | UNDER_AGREEMENT | IN_ESCROW | LISTED | CLOSED | DEAD
// AgreementType  = PURCHASE | OPTION
// ContactType    = SELLER | REALTOR | ESCROW_OFFICER | PHOTOGRAPHER | TRANSACTION_COORDINATOR | OTHER
// TemplateFormat = DOCX | PDF
// DocStatus      = DRAFT | SENT | VIEWED | SIGNED | COMPLETED | VOIDED
// EmailDirection = INBOUND | OUTBOUND

// ────────────────────────────────────────────────────────────
//  Property
// ────────────────────────────────────────────────────────────

model Property {
  id          String   @id @default(cuid())
  address     String
  city        String?
  state       String?
  zip         String?
  bedrooms    Int?
  bathrooms   Float?
  sqft        Int?
  lotSize     Int?
  yearBuilt   Int?
  apn         String?
  taxRollData String? // JSON
  mlsListed   Boolean  @default(false)
  mlsNumber   String?
  photos      String? // JSON array of URLs
  deal        Deal?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ────────────────────────────────────────────────────────────
//  Contacts
// ────────────────────────────────────────────────────────────

model Contact {
  id             String   @id @default(cuid())
  type           String // ContactType
  firstName      String
  lastName       String?
  email          String?
  phone          String?
  company        String?
  notes          String?
  dealsAsSeller  Deal[]   @relation("DealSeller")
  dealsAsRealtor Deal[]   @relation("DealRealtor")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([type])
}

// ────────────────────────────────────────────────────────────
//  Templates & Documents
// ────────────────────────────────────────────────────────────

model Template {
  id               String     @id @default(cuid())
  name             String
  description      String?
  format           String // DOCX | PDF
  originalFileUrl  String
  tokenizedFileUrl String?
  bindings         String     @default("[]") // JSON array of Binding objects
  documents        Document[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model Document {
  id                 String   @id @default(cuid())
  deal               Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId             String
  template           Template @relation(fields: [templateId], references: [id])
  templateId         String
  fileUrl            String
  docusignEnvelopeId String?
  status             String   @default("DRAFT") // DocStatus
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([dealId])
  @@index([status])
}

// ────────────────────────────────────────────────────────────
//  Tasks
// ────────────────────────────────────────────────────────────

model Task {
  id          String    @id @default(cuid())
  deal        Deal?     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId      String?
  title       String
  notes       String?
  dueDate     DateTime?
  completedAt DateTime?
  assignee    User?     @relation(fields: [assigneeId], references: [id])
  assigneeId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([dueDate])
  @@index([dealId])
}

// ────────────────────────────────────────────────────────────
//  Email thread (Phase B Gmail intake)
// ────────────────────────────────────────────────────────────

model EmailMessage {
  id          String   @id @default(cuid())
  deal        Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  dealId      String?
  direction   String // INBOUND | OUTBOUND
  fromAddress String
  toAddress   String
  subject     String?
  bodyHtml    String?
  bodyText    String?
  receivedAt  DateTime
  parsedJson  String? // JSON
  gmailId     String?  @unique
  createdAt   DateTime @default(now())

  @@index([dealId])
}
