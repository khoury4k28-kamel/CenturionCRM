# ── Local dev (Prisma + SQLite) ─────────────────────────────
DATABASE_URL="file:./dev.db"

# ── Liveblocks (production / GitHub Pages) ──────────────────
# Public key from the Liveblocks dashboard. When unset, the app stays
# in local mode and uses the API routes + Prisma. When set, the
# BackendDataProvider routes reads/writes through Liveblocks instead.
# NEXT_PUBLIC_* is exposed to the client bundle — that's expected; this
# is the public key, auth happens server-side at Liveblocks.
# NEXT_PUBLIC_LIVEBLOCKS_PUBLIC_KEY=pk_dev_XXXXXXXXXXXX

# Optional: override the Liveblocks room ID. Defaults to "centurion-crm".
# Useful if you're sharing a Liveblocks workspace across staging/prod.
# NEXT_PUBLIC_LIVEBLOCKS_ROOM_ID=centurion-crm-staging
