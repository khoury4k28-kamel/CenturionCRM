# ── Local dev (Prisma + SQLite) ─────────────────────────────
DATABASE_URL="file:./dev.db"

# ── Liveblocks (production / GitHub Pages) ──────────────────
# Public key from the Liveblocks dashboard. When unset, the app stays
# in local mode and uses the API routes + Prisma. When set, the
# BackendDataProvider routes reads/writes through Liveblocks instead.
# NEXT_PUBLIC_* is exposed to the client bundle — that's expected; this
# is the public key, auth happens server-side at Liveblocks.
# NEXT_PUBLIC_LIVEBLOCKS_PUBLIC_KEY=pk_dev_XXXXXXXXXXXX

# Optional: override the Liveblocks room ID. Defaults to "centurion-crm".
# Useful if you're sharing a Liveblocks workspace across staging/prod.
# NEXT_PUBLIC_LIVEBLOCKS_ROOM_ID=centurion-crm-staging

# ── Google sign-in (hosted mode only) ───────────────────────
# OAuth 2.0 Client ID from Google Cloud Console. Required for sign-in when
# running with Liveblocks enabled. Without it, AuthGate shows a "not
# configured" screen.
# Get one at: https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins must include:
#   - http://localhost:3000 (local dev with Liveblocks)
#   - https://<your-handle>.github.io (GitHub Pages prod URL)
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=123456789012-xxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

# Comma-separated list of owner emails. Owners bypass the in-app allowlist
# and can edit it (grant/revoke access for other users). At least one owner
# must always be set — otherwise the first deploy has no one who can sign in.
# NEXT_PUBLIC_OWNER_EMAILS=khoury4k28@gmail.com
